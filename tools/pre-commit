#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# Pre-commit hook for superpowers-plus
# PURPOSE: Block commits that violate quality standards
# INSTALL: cp tools/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#          OR: ./tools/install-hooks.sh
# -----------------------------------------------------------------------------
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [[ -z "$REPO_ROOT" ]]; then
    # Fallback for manual execution outside a git worktree context.
    if [[ "$SCRIPT_DIR" == *".git/hooks"* ]]; then
        REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    else
        REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
    fi
fi

# Canonicalize to physical path so symlinked paths (/var → /private/var)
# match the path stored in review tokens by harsh-review.sh (pwd -P).
REPO_ROOT="$(cd "$REPO_ROOT" && pwd -P 2>/dev/null)" || true

cd "$REPO_ROOT"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

# -----------------------------------------------------------------------------
# Per-repo manifest: .agent-gates (data-parsed, optional)
#
# Create .agent-gates in a repo to customise which checks run:
#
#   CLASS=node            # repo type: markdown-only | shell | node | python
#   SKIP_SHELLCHECK=true  # disable shellcheck (e.g. repo has no shell files)
#   SKIP_FILE_ENDINGS=true
#   EXTRA_LINT="npm run lint"
#   EXTRA_TYPECHECK="npm run typecheck"
#   EXTRA_TEST="npm run test:affected"
#
# Repos without .agent-gates run all default checks (fail-safe default).
#
# SECURITY: .agent-gates is parsed as data (KEY=VALUE only), NOT sourced.
# Sourcing it before Gate 0 would allow a staged .agent-gates change to
# inject arbitrary shell code or unset REQUIRE_CODE_REVIEW_SENTINEL before
# the sentinel check runs. Only the known keys listed below are extracted.
# -----------------------------------------------------------------------------
if [[ -f "$REPO_ROOT/.agent-gates" ]]; then
    while IFS='=' read -r _key _remainder; do
        # Skip blank lines and comment lines
        [[ -z "$_key" || "$_key" =~ ^[[:space:]]*# ]] && continue
        # Trim whitespace from key
        _key="${_key//[[:space:]]/}"
        # Only accept known keys; ignore everything else silently
        case "$_key" in
            CLASS|SKIP_SHELLCHECK|SKIP_FILE_ENDINGS|EXTRA_LINT|EXTRA_TYPECHECK|EXTRA_TEST|REQUIRE_CODE_REVIEW_SENTINEL|REVIEW_TOKEN_TTL|SKIP_REVIEW_TOKEN|REQUIRE_LOOSE_ENDS_CLEAN)
                # Trim leading/trailing whitespace and strip surrounding quotes
                _remainder="${_remainder#"${_remainder%%[![:space:]]*}"}"
                _remainder="${_remainder%"${_remainder##*[![:space:]]}"}"
                _remainder="${_remainder#\"}" ; _remainder="${_remainder%\"}"
                _remainder="${_remainder#\'}" ; _remainder="${_remainder%\'}"
                printf -v "$_key" '%s' "$_remainder"
                ;;
            *) ;;
        esac
    done < "$REPO_ROOT/.agent-gates"
fi
# Variables optionally set by .agent-gates: CLASS EXTRA_LINT EXTRA_TYPECHECK EXTRA_TEST

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  PRE-COMMIT: Running quality checks..."
[[ -n "$CLASS" ]] && echo "  Repo class: $CLASS"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Get staged files — include Renamed and Type-changed so rename-only code
# commits are not silently exempted from quality gates (including Gate 0).
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMRT)

if [[ -z "$STAGED_FILES" ]]; then
    echo -e "${GREEN}No files staged for commit.${NC}"
    exit 0
fi

ERRORS=0

# -----------------------------------------------------------------------------
# GATE 0: Code Review Sentinel (opt-in via REQUIRE_CODE_REVIEW_SENTINEL=true)
#
# Purpose: Early presence gate — verifies that code-review-battery was run
#          before any code is committed. This is intentionally a "was battery
#          run at all?" check, not an identity gate. SHA-specific enforcement
#          (sentinel SHA == pushed ref SHA) happens in pre-push Gate 1.
#
# Why the split: battery runs POST-commit so HEAD is the actual commit SHA.
#   pre-commit: sentinel must exist with a valid passing verdict
#   pre-push:   sentinel SHA must match the exact ref being pushed
# This two-checkpoint design means: run battery → push (not run battery →
# commit → re-run battery → push). A staleness warning fires when the sentinel
# is for a different HEAD, so the agent knows pre-push will require re-review.
#
# Policy files AGENTS.md and CLAUDE.md are treated as code (not docs) because
# changes to them alter agent gate behavior. See staged_has_code() below.
# -----------------------------------------------------------------------------
SENTINEL_FILE="$REPO_ROOT/.code-review-cleared"

staged_has_code() {
    # Returns 0 (true) if staged files include any non-doc, non-metadata file.
    # ACDMRT covers Added, Copied, Deleted, Modified, Renamed, Type-changed —
    # deleted code files still require review clearance. Note: STAGED_FILES
    # intentionally omits D because downstream content checks require the file
    # to exist on disk; this helper is existence-independent.
    #
    # AGENTS.md and CLAUDE.md are policy files — treated as code. Changes to
    # them alter agent gate behavior and require battery clearance. They are
    # explicitly preserved by the awk filter before the generic .md exemption.
    local staged_code
    staged_code=$(git diff --cached --name-only --diff-filter=ACDMRT 2>/dev/null \
        | awk '
            /^\s*$/                             { next }
            /^(AGENTS|CLAUDE)(\.md)?$/          { print; next }
            /^skills\//                         { print; next }
            /\.(md|txt|rst)$/                   { next }
            /^(\.gitignore|\.gitattributes|\.editorconfig|README|CHANGELOG|LICENSE|\.env\.example)$/ { next }
            { print }
        ' \
        | head -1 || true)
    [[ -n "$staged_code" ]]
}

if [[ "${REQUIRE_CODE_REVIEW_SENTINEL:-false}" == "true" ]]; then
    echo -e "${YELLOW}[0/5]${NC} Checking code review sentinel..."
    if staged_has_code; then
        if [[ ! -f "$SENTINEL_FILE" ]]; then
            echo ""
            echo -e "  ${RED}❌ COMMIT BLOCKED: No code review clearance.${NC}"
            echo ""
            echo "  Code changes require code-review-battery before committing."
            echo "  Run battery → it writes .code-review-cleared → then commit."
            echo ""
            ERRORS=$((ERRORS + 1))
        else
            sentinel_ver=$(cut -d'|' -f1 < "$SENTINEL_FILE" 2>/dev/null || echo "")
            sentinel_sha=$(cut -d'|' -f2 < "$SENTINEL_FILE" 2>/dev/null || echo "")
            sentinel_verdict=$(cut -d'|' -f3 < "$SENTINEL_FILE" 2>/dev/null || echo "")
            sentinel_ts=$(cut -d'|' -f4 < "$SENTINEL_FILE" 2>/dev/null || echo "")
            field_count=$(awk -F'|' '{print NF}' "$SENTINEL_FILE" 2>/dev/null || echo "0")

            if [[ "$sentinel_ver" != "v1" || "$field_count" != "4" || -z "$sentinel_sha" || -z "$sentinel_ts" ]]; then
                echo -e "  ${RED}❌ COMMIT BLOCKED: Sentinel format invalid (expected v1|SHA|VERDICT|TIMESTAMP, all fields non-empty).${NC}"
                echo "  Delete .code-review-cleared and re-run code-review-battery."
                ERRORS=$((ERRORS + 1))
            elif [[ "$sentinel_verdict" != "PASS" && "$sentinel_verdict" != "PASS_WITH_NITS" ]]; then
                echo -e "  ${RED}❌ COMMIT BLOCKED: Last review verdict was '${sentinel_verdict}'.${NC}"
                echo "  Fix all Critical/Important findings and re-run code-review-battery."
                ERRORS=$((ERRORS + 1))
            else
                echo -e "  ${GREEN}✓ Code review cleared: ${sentinel_verdict} (${sentinel_sha:0:8}, ${sentinel_ts})${NC}"
                # Staleness warning: if sentinel covers a different HEAD, pre-push will
                # require re-review once the commit creates a new SHA.
                current_head=$(git rev-parse HEAD 2>/dev/null || echo "")
                if [[ -n "$current_head" && "$sentinel_sha" != "$current_head" ]]; then
                    echo -e "  ${YELLOW}  ⚠ Sentinel is for ${sentinel_sha:0:8}; HEAD is ${current_head:0:8}.${NC}"
                    echo -e "  ${YELLOW}  Run battery on HEAD before pushing — pre-push will compare sentinel to pushed ref.${NC}"
                else
                    echo -e "  ${YELLOW}  pre-push will re-verify that this SHA matches the pushed ref.${NC}"
                fi
            fi
        fi
    else
        echo -e "  ${YELLOW}  Docs/metadata only — sentinel not required.${NC}"
    fi
fi

# -----------------------------------------------------------------------------
# CHECK 1: File endings (single newline at EOF)
# -----------------------------------------------------------------------------
echo -e "${YELLOW}[1/5]${NC} Checking file endings..."

for file in $STAGED_FILES; do
    [[ ! -f "$file" ]] && continue

    # Skip binary files
    if file "$file" | grep -q "binary"; then
        continue
    fi

    # Check for extra blank lines at EOF
    if tail -c 2 "$file" 2>/dev/null | xxd -p | grep -q "0a0a"; then
        echo -e "${RED}  ✗ $file: extra blank line at EOF${NC}"
        ERRORS=$((ERRORS + 1))
    fi

    # Check for missing final newline
    if [[ $(tail -c 1 "$file" 2>/dev/null | wc -l) -eq 0 ]]; then
        echo -e "${RED}  ✗ $file: missing final newline${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# -----------------------------------------------------------------------------
# CHECK 2: Shell script syntax
# -----------------------------------------------------------------------------
echo -e "${YELLOW}[2/5]${NC} Checking shell scripts..."

for file in $STAGED_FILES; do
    [[ "$file" != *.sh ]] && continue
    [[ ! -f "$file" ]] && continue

    if ! bash -n "$file" 2>/dev/null; then
        echo -e "${RED}  ✗ $file: bash syntax error${NC}"
        ERRORS=$((ERRORS + 1))
    fi

    # Check shebang
    shebang=$(head -n1 "$file")
    if [[ "$shebang" == "#!/bin/bash" ]]; then
        echo -e "${RED}  ✗ $file: use '#!/usr/bin/env bash' not '#!/bin/bash'${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# -----------------------------------------------------------------------------
# CHECK 3: JSON syntax
# -----------------------------------------------------------------------------
echo -e "${YELLOW}[3/5]${NC} Checking JSON files..."

for file in $STAGED_FILES; do
    [[ "$file" != *.json ]] && continue
    [[ ! -f "$file" ]] && continue

    if ! python3 -c "import json; json.load(open('$file'))" 2>/dev/null; then
        echo -e "${RED}  ✗ $file: invalid JSON${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# -----------------------------------------------------------------------------
# CHECK 4: Shellcheck (if available)
# -----------------------------------------------------------------------------
echo -e "${YELLOW}[4/5]${NC} Running shellcheck..."

# Same exclusions as CI and harsh-review.sh
SHELLCHECK_EXCLUDES="SC1091,SC2034,SC2129,SC2155,SC2162,SC2097,SC2098,SC2015,SC2317,SC2064"

if command -v shellcheck &> /dev/null; then
    for file in $STAGED_FILES; do
        [[ "$file" != *.sh ]] && continue
        [[ ! -f "$file" ]] && continue

        if ! shellcheck -e "$SHELLCHECK_EXCLUDES" "$file" 2>/dev/null; then
            echo -e "${RED}  ✗ $file: shellcheck violations${NC}"
            ERRORS=$((ERRORS + 1))
        fi
    done
else
    echo -e "  (shellcheck not installed, skipping)"
fi

# -----------------------------------------------------------------------------
# CHECK 5: Proprietary IP scan (if .ip-patterns exists)
# -----------------------------------------------------------------------------
echo -e "${YELLOW}[5/5]${NC} Checking for proprietary IP..."

IP_AUDIT_SCRIPT="$REPO_ROOT/tools/public-repo-ip-check.sh"
if [[ -f "$IP_AUDIT_SCRIPT" ]]; then
    if ! bash "$IP_AUDIT_SCRIPT" --staged-only; then
        ERRORS=$((ERRORS + 1))
    fi
else
    echo -e "${RED}  ✗ tools/public-repo-ip-check.sh missing${NC}"
    ERRORS=$((ERRORS + 1))
fi

# -----------------------------------------------------------------------------
# CHECK 6: Loose-ends scan (always runs; blocks only if REQUIRE_LOOSE_ENDS_CLEAN=true)
#
# Part A: scan-staged — greps staged diff for TODO/FIXME/HACK in code files.
#         Surfaces code debt introduced in THIS commit so the agent can decide
#         whether to record it via loose-ends.sh add before committing.
#
# Part B: check — audits open #loose-end items in the TODO store.
#         Always warns; blocks the commit if REQUIRE_LOOSE_ENDS_CLEAN=true is
#         set in .agent-gates (opt-in per repo, default: warn only).
#
# Why warn-only by default: some #loose-end items are legitimately deferred
# across sessions. Blocking every commit would be too aggressive.
# -----------------------------------------------------------------------------
LOOSE_ENDS_SCRIPT="$SCRIPT_DIR/loose-ends.sh"

if [[ -f "$LOOSE_ENDS_SCRIPT" ]]; then
    echo -e "${YELLOW}[6/+]${NC} Scanning staged changes for code debt..."
    # Capture output + exit status safely under set -euo pipefail using 'if'
    scan_output=""; scan_ok=true
    if ! scan_output=$(bash "$LOOSE_ENDS_SCRIPT" scan-staged 2>&1); then
        scan_ok=false
    fi
    if [[ "$scan_ok" == "false" ]]; then
        echo "$scan_output"
        echo -e "  ${YELLOW}  Record via: loose-ends.sh add --desc '...' --note '...'${NC}"
        if [[ "${REQUIRE_LOOSE_ENDS_CLEAN:-false}" == "true" ]]; then
            ERRORS=$((ERRORS + 1))
        fi
    else
        echo -e "  ${GREEN}✓ No code debt markers in staged changes.${NC}"
    fi

    echo -e "${YELLOW}[7/+]${NC} Checking for open #loose-end items..."
    check_output=""; check_ok=true
    if ! check_output=$(bash "$LOOSE_ENDS_SCRIPT" check 2>&1); then
        check_ok=false
    fi
    if [[ "$check_ok" == "false" ]]; then
        echo "$check_output"
        if [[ "${REQUIRE_LOOSE_ENDS_CLEAN:-false}" == "true" ]]; then
            echo -e "  ${RED}  REQUIRE_LOOSE_ENDS_CLEAN=true: resolve or justify all #loose-end items before committing.${NC}"
            ERRORS=$((ERRORS + 1))
        fi
    else
        echo -e "  ${GREEN}✓ No open #loose-end items.${NC}"
    fi
fi

# -----------------------------------------------------------------------------
# EXTRA CHECKS: Manifest-declared repo-specific gates (.agent-gates)
# These run AFTER the base 5 checks. Declare in .agent-gates:
#   EXTRA_LINT="npm run lint"
#   EXTRA_TYPECHECK="npm run typecheck"
#   EXTRA_TEST="npm run test:affected"
# -----------------------------------------------------------------------------
EXTRA_IDX=6
for EXTRA_CMD_VAR in EXTRA_LINT EXTRA_TYPECHECK EXTRA_TEST; do
    EXTRA_CMD="${!EXTRA_CMD_VAR:-}"
    [[ -z "$EXTRA_CMD" ]] && continue
    echo -e "${YELLOW}[${EXTRA_IDX}/+]${NC} Running ${EXTRA_CMD_VAR}: ${EXTRA_CMD}..."
    if ! eval "$EXTRA_CMD" 2>&1; then
        echo -e "${RED}  ✗ ${EXTRA_CMD_VAR} failed${NC}"
        ERRORS=$((ERRORS + 1))
    fi
    EXTRA_IDX=$((EXTRA_IDX + 1))
done

# -----------------------------------------------------------------------------
# REVIEW TOKEN CHECK: Verify harsh-review.sh ran recently
# Skip if SKIP_REVIEW_TOKEN=true in .agent-gates
# -----------------------------------------------------------------------------
if [[ "${SKIP_REVIEW_TOKEN:-}" != "true" ]]; then
    REVIEW_TOKEN_DIR="${HOME}/.codex/review-tokens"
    REVIEW_TTL="${REVIEW_TOKEN_TTL:-300}"
    NOW=$(date +%s)
    FOUND_VALID_TOKEN=false

    # _token_epoch: extract epoch from both old (pure-digits) and new
    # (<cksum>.<epoch>.<pid>) filename formats.
    _token_epoch() { local b; b=$(basename "$1")
        if [[ "$b" =~ ^[0-9]+$ ]]; then echo "$b"
        else echo "$b" | awk -F'.' '{print $2}'; fi
    }

    if [[ -d "$REVIEW_TOKEN_DIR" ]]; then
        for token_file in "$REVIEW_TOKEN_DIR"/*; do
            [[ -f "$token_file" ]] || continue
            token_ts=$(_token_epoch "$token_file")
            [[ "$token_ts" =~ ^[0-9]+$ ]] || continue
            token_age=$((NOW - token_ts))
            if [[ $token_age -le $REVIEW_TTL ]]; then
                token_repo=$(cat "$token_file" 2>/dev/null || true)
                if [[ "$token_repo" == "$REPO_ROOT" ]]; then
                    FOUND_VALID_TOKEN=true
                    # Consume the token (one-time use)
                    rm -f "$token_file"
                    break
                fi
            fi
        done
    fi

    echo -e "${YELLOW}[+]${NC} Checking review token (TTL=${REVIEW_TTL}s)..."
    if [[ "$FOUND_VALID_TOKEN" == "true" ]]; then
        echo -e "${GREEN}  ✓ Valid review token found${NC}"
    else
        echo -e "${RED}  ✗ No valid review token found${NC}"
        echo -e "${RED}    Run: bash tools/harsh-review.sh${NC}"
        echo -e "${RED}    Or skip: SKIP_REVIEW_TOKEN=true in .agent-gates${NC}"
        ERRORS=$((ERRORS + 1))
    fi

    # Garbage-collect expired tokens — repo-scoped (only delete current repo's
    # tokens to avoid inadvertently removing another repo's still-valid token).
    if [[ -d "$REVIEW_TOKEN_DIR" ]]; then
        for token_file in "$REVIEW_TOKEN_DIR"/*; do
            [[ -f "$token_file" ]] || continue
            token_ts=$(_token_epoch "$token_file")
            [[ "$token_ts" =~ ^[0-9]+$ ]] || continue
            token_age=$((NOW - token_ts))
            if [[ $token_age -gt $((REVIEW_TTL * 2)) ]]; then
                token_repo=$(cat "$token_file" 2>/dev/null || true)
                # Only remove tokens belonging to this repo
                if [[ "$token_repo" == "$REPO_ROOT" ]]; then
                    rm -f "$token_file"
                fi
            fi
        done
    fi
fi

# -----------------------------------------------------------------------------
# RESULT
# -----------------------------------------------------------------------------
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}  COMMIT BLOCKED: $ERRORS error(s) found${NC}"
    echo ""
    echo "  Fix the errors above, then:"
    echo "    git add <files>"
    echo "    git commit"
    echo ""
    echo "  To bypass (skips all gates — use only in emergencies):"
    echo "    git commit --no-verify"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
else
    echo -e "${GREEN}  All checks passed!${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
fi
