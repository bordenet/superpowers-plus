#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# commit-msg hook — enforce ASCII-only commit messages
# PURPOSE: Auto-convert common Unicode punctuation to ASCII equivalents, then
#          reject any remaining non-ASCII characters with a clear diagnostic.
#          GitLab pre-receive hooks block non-ASCII commit messages; catching
#          them here gives a fast, local fix rather than a remote rejection.
# INSTALL: ./tools/install-hooks.sh
# -----------------------------------------------------------------------------
set -euo pipefail

COMMIT_MSG_FILE="$1"
[[ -f "$COMMIT_MSG_FILE" ]] || exit 0

# Auto-convert known safe Unicode → ASCII substitutions in-place.
python3 - "$COMMIT_MSG_FILE" <<'PYEOF'
import sys, re

SUBSTITUTIONS = [
    ('—', '-'),   # em dash   — → -
    ('–', '-'),   # en dash   – → -
    ('‒', '-'),   # figure dash
    ('‐', '-'),   # hyphen
    ('→', '->'),  # right arrow →
    ('←', '<-'),  # left arrow  ←
    ('…', '...'), # ellipsis   …
    ('‘', "'"),   # left single quote  '
    ('’', "'"),   # right single quote '
    ('“', '"'),   # left double quote  "
    ('”', '"'),   # right double quote "
    ('·', '*'),   # middle dot ·
    ('•', '-'),   # bullet     •
]

path = sys.argv[1]
with open(path, encoding='utf-8', errors='replace') as f:
    text = f.read()

for src, dst in SUBSTITUTIONS:
    text = text.replace(src, dst)

with open(path, 'w', encoding='utf-8') as f:
    f.write(text)
PYEOF

# After substitutions, reject any remaining non-ASCII characters.
if LC_ALL=C grep -Pn '[^\x00-\x7F]' "$COMMIT_MSG_FILE" >/dev/null 2>&1; then
    echo "" >&2
    echo "  ERROR: commit message contains non-ASCII characters." >&2
    echo "  GitLab pre-receive rejects non-ASCII commit messages." >&2
    echo "" >&2
    echo "  Offending lines:" >&2
    LC_ALL=C grep -Pn '[^\x00-\x7F]' "$COMMIT_MSG_FILE" | while IFS= read -r line; do
        echo "    $line" >&2
    done
    echo "" >&2
    echo "  Replace the characters above with ASCII equivalents and retry." >&2
    echo "" >&2
    exit 1
fi

exit 0
