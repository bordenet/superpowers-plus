#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# Pre-push hook for superpowers-plus
# PURPOSE: Block pushes that contain proprietary IP in unpushed commits
# INSTALL: ./tools/install-hooks.sh
# -----------------------------------------------------------------------------
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "$SCRIPT_DIR" == *".git/hooks"* ]]; then
    REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
else
    REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

IP_PATTERNS_FILE="$REPO_ROOT/.ip-patterns"
if [[ ! -f "$IP_PATTERNS_FILE" ]]; then
    echo -e "${GREEN}No .ip-patterns file — skipping IP scan.${NC}"
    exit 0
fi

IP_PATTERNS=$(cat "$IP_PATTERNS_FILE" | head -1)

# Remote name is passed as $1 by git
REMOTE_NAME="${1:-origin}"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  PRE-PUSH: Scanning for proprietary IP..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ERRORS=0

# Read push info from stdin (pre-push hook protocol)
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        continue  # Branch deletion, skip
    fi

    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        # New branch — find merge-base with remote's default branch
        # This prevents scanning the entire history
        REMOTE_DEFAULT=""
        for candidate in "$REMOTE_NAME/main" "$REMOTE_NAME/master"; do
            if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
                REMOTE_DEFAULT="$candidate"
                break
            fi
        done
        if [[ -n "$REMOTE_DEFAULT" ]]; then
            MERGE_BASE=$(git merge-base "$local_sha" "$REMOTE_DEFAULT" 2>/dev/null || true)
            if [[ -n "$MERGE_BASE" ]]; then
                RANGE="$MERGE_BASE..$local_sha"
            else
                RANGE="$local_sha"
            fi
        else
            RANGE="$local_sha"
        fi
    else
        RANGE="$remote_sha..$local_sha"
    fi

    echo "Checking commits: $RANGE"

    # Check commit diffs for IP patterns (added lines only — removals are safe)
    MATCHES=$(git log -p "$RANGE" 2>/dev/null | grep -E '^\+' | grep -cE "$IP_PATTERNS" || true)
    if [[ "$MATCHES" -gt 0 ]]; then
        echo -e "${RED}❌ FAIL: $MATCHES proprietary IP matches in added lines${NC}"
        git log -p "$RANGE" | grep -E '^\+' | grep -nE "$IP_PATTERNS" | head -10
        ((ERRORS++))
    fi

    # Check author/committer emails against IP patterns from file
    # (uses .ip-patterns to avoid hardcoding proprietary strings in this script)
    BAD_EMAILS=$(git log "$RANGE" --format='%ae%n%ce' 2>/dev/null | sort -u | grep -iE "$IP_PATTERNS" || true)
    if [[ -n "$BAD_EMAILS" ]]; then
        echo -e "${RED}❌ FAIL: Proprietary email in commit metadata: $BAD_EMAILS${NC}"
        ((ERRORS++))
    fi
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}  PUSH BLOCKED: Proprietary IP detected in commits${NC}"
    echo ""
    echo "  Fix the content, amend/rebase, then push again."
    echo "  DO NOT use --no-verify."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
else
    echo -e "${GREEN}  All commits clean. Push allowed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
fi
