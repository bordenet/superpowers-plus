#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# Pre-push hook for superpowers-plus
# PURPOSE: Block pushes that contain proprietary IP in unpushed commits
# INSTALL: ./tools/install-hooks.sh
# -----------------------------------------------------------------------------
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [[ -z "$REPO_ROOT" ]]; then
    if [[ "$SCRIPT_DIR" == *".git/hooks"* ]]; then
        REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    else
        REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
    fi
fi

cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

# -----------------------------------------------------------------------------
# Code Review Sentinel Check
# Purpose: Block pushes of code changes that have not been cleared by
#          code-review-battery. The battery writes .code-review-cleared
#          (format: v1|SHA|VERDICT|TIMESTAMP) when it passes. This hook
#          verifies the clearance exists, matches the pushed ref SHA, and has a
#          passing verdict.
# Bypass:  Local git hooks can be bypassed with --no-verify. This is a
#          workflow gate, not a security boundary. For hard enforcement, add
#          server-side push rules or CI required checks.
# Threat:  Local soft gate only. An agent can forge the file. This is
#          intentional — policy-enforced, not security-enforced.
# -----------------------------------------------------------------------------
SENTINEL_FILE="$REPO_ROOT/.code-review-cleared"
MERGE_DISCIPLINE_SENTINEL="$REPO_ROOT/.merge-discipline-cleared"

# Reads filenames from stdin, prints the first one that is classified as code,
# or prints nothing if all files are docs/metadata. Used by both range_is_docs_only()
# and the NEW_BRANCH_NO_BASE block so the classification rules stay in one place.
# AGENTS.md / CLAUDE.md are policy files treated as code; skills/ is always code;
# .md/.txt/.rst and well-known root metadata files are exempted.
_first_code_file() {
    awk '
        /^\s*$/                             { next }
        /^(AGENTS|CLAUDE)(\.md)?$/          { print; next }
        /^skills\//                         { print; next }
        /\.(md|txt|rst)$/                   { next }
        /^(\.gitignore|\.gitattributes|\.editorconfig|README|CHANGELOG|LICENSE|\.env\.example)$/ { next }
        { print }
    ' | head -1
}

# Returns 0 if the range contains only prose/metadata files that cannot alter
# runtime behavior. JSON/YAML/TOML/shell config ARE code for purposes of this
# check — they can change scope guards, deploy behavior, and security boundaries.
# Only pure docs and well-known root metadata files are exempted.
range_is_docs_only() {
    local range="$1"
    local all_files code_files
    # For single-SHA ranges (new branch with no merge-base), git diff compares
    # to the working tree — use diff-tree instead to enumerate only the commit's
    # changed files. --root handles root commits; -m handles merge commits (lists
    # files relative to each parent); sort -u deduplicates multi-parent output.
    # Use `if !` to fail closed on git errors without triggering set -e: if we
    # cannot enumerate files, treat the range as code (require sentinel).
    if [[ "$range" != *".."* ]]; then
        if ! all_files=$(git diff-tree --root -m --no-commit-id --name-only -r "${range}" 2>/dev/null | sort -u); then
            return 1  # Cannot enumerate commit files — fail closed (not docs-only)
        fi
    else
        if ! all_files=$(git diff --name-only "$range" 2>/dev/null); then
            return 1  # Cannot enumerate range files — fail closed
        fi
    fi
    # The || true is scoped to the FILTER pipeline only — not the git commands
    # above — so real git failures still fail closed (return 1 via if ! above).
    code_files=$(printf '%s\n' "$all_files" | _first_code_file || true)
    [[ -z "$code_files" ]]
}

# $1 = RANGE (commit range being pushed)
# $2 = local_sha (the actual ref SHA being pushed — may differ from HEAD)
check_code_review_sentinel() {
    local range="$1"
    local pushed_sha="$2"

    if range_is_docs_only "$range"; then
        echo -e "  ${YELLOW}[code-review-gate]${NC} Docs only — sentinel not required."
        return 0
    fi

    echo "  [code-review-gate] Code changes detected — checking clearance..."

    if [[ ! -f "$SENTINEL_FILE" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: No code review clearance found.${NC}"
        echo ""
        echo "  Code changes require code-review-battery before pushing."
        echo "  The battery writes .code-review-cleared when it passes PASS or PASS_WITH_NITS."
        echo ""
        echo "  Steps:"
        echo "    1. node ~/.codex/superpowers-augment/superpowers-augment.js use-skill code-review-battery"
        echo "    2. Dispatch reviewers with: git diff \$(git merge-base HEAD \$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || echo 'origin/dev'))..HEAD"
        echo "    3. Battery writes .code-review-cleared on PASS/PASS_WITH_NITS"
        echo "    4. git push"
        echo ""
        return 1
    fi

    local sentinel_ver sentinel_sha sentinel_verdict sentinel_ts
    sentinel_ver=$(cut -d'|' -f1 < "$SENTINEL_FILE" 2>/dev/null || echo "")
    sentinel_sha=$(cut -d'|' -f2 < "$SENTINEL_FILE" 2>/dev/null || echo "")
    sentinel_verdict=$(cut -d'|' -f3 < "$SENTINEL_FILE" 2>/dev/null || echo "")
    sentinel_ts=$(cut -d'|' -f4 < "$SENTINEL_FILE" 2>/dev/null || echo "")

    # Validate v1 format: 4 or 5 pipe-delimited fields. Field 1 = "v1",
    # field 2 (sha) and field 4 (timestamp) non-empty. Optional field 5 = min-score=N.
    local field_count
    field_count=$(awk -F'|' '{print NF}' "$SENTINEL_FILE" 2>/dev/null || echo "0")

    if [[ "$sentinel_ver" != "v1" ]] || [[ "$field_count" -lt 4 ]] || [[ "$field_count" -gt 5 ]] || [[ -z "$sentinel_sha" ]] || [[ -z "$sentinel_ts" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: Sentinel file format unrecognized (expected v1|SHA|VERDICT|TIMESTAMP[|min-score=N], all fields non-empty).${NC}"
        echo ""
        echo "  Delete .code-review-cleared and re-run code-review-battery."
        echo ""
        return 1
    fi

    if [[ "$field_count" -eq 5 ]]; then
        local sentinel_min_score
        sentinel_min_score=$(cut -d'|' -f5 "$SENTINEL_FILE" 2>/dev/null || echo "")
        if ! [[ "$sentinel_min_score" =~ ^min-score=[0-9]+(\.[0-9]+)?$ ]]; then
            echo ""
            echo -e "  ${RED}❌ PUSH BLOCKED: Sentinel field 5 malformed: '${sentinel_min_score}' (expected min-score=N.N).${NC}"
            echo ""
            echo "  Delete .code-review-cleared and re-run code-review-battery."
            echo ""
            return 1
        fi
    fi

    # Compare against the ref actually being pushed, not necessarily HEAD.
    # Pre-push hooks can push non-HEAD refs (e.g., worktrees, detached heads).
    if [[ "$sentinel_sha" != "$pushed_sha" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: Code review clearance is stale.${NC}"
        echo ""
        echo "  Clearance was for commit: ${sentinel_sha:0:8}"
        echo "  Pushing commit:           ${pushed_sha:0:8}"
        echo ""
        echo "  Commits were made after the review. Re-run code-review-battery, then push."
        echo ""
        return 1
    fi

    if [[ "$sentinel_verdict" != "PASS" && "$sentinel_verdict" != "PASS_WITH_NITS" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: Code review verdict was not passing.${NC}"
        echo ""
        echo "  Last verdict: $sentinel_verdict (at $sentinel_ts)"
        echo "  Fix all Critical and Important findings, re-run battery."
        echo ""
        return 1
    fi

    echo -e "  ${GREEN}✓ Code review cleared: $sentinel_verdict (${sentinel_sha:0:8}, $sentinel_ts)${NC}"
    return 0
}

# Remote name is passed as $1 by git
REMOTE_NAME="${1:-origin}"

# Determine if this is a public remote that requires IP scanning.
# Public hosting domains (GitHub, GitLab.com, Bitbucket) are public by definition.
# Private/internal remotes (self-hosted GitLab, local file paths, etc.) do NOT
# need the IP scan — pushing already-audited-public content to a private repo
# cannot leak IP to an external party. The sentinel (code-review) gate still
# applies to all remotes.
REMOTE_URL="$(git remote get-url "$REMOTE_NAME" 2>/dev/null || echo "")"
IS_PUBLIC_REMOTE=true   # fail closed: unknown/empty URL → treat as public, run all gates
# Match both HTTPS (https://github.com/...) and SSH (git@github.com:...) URLs.
# Only downgrade to private when we positively identify a non-public URL.
# Empty URL (no remote configured, test fixtures) → fail closed → gates run.
if [[ -n "$REMOTE_URL" ]] && ! echo "$REMOTE_URL" | grep -qE '(github\.com|gitlab\.com|bitbucket\.org)'; then
    IS_PUBLIC_REMOTE=false
fi

resolve_push_base_ref() {
    local candidate tracking
    tracking="$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)"

    for candidate in \
        "$tracking" \
        "$REMOTE_NAME/dev" "$REMOTE_NAME/staging" "$REMOTE_NAME/main" "$REMOTE_NAME/master" \
        origin/dev origin/staging origin/main origin/master \
        upstream/dev upstream/staging upstream/main upstream/master \
        gitlab/dev gitlab/staging gitlab/main gitlab/master
    do
        [[ -n "$candidate" ]] || continue
        if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  PRE-PUSH: Running quality gates..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Private remotes are downstream mirrors of origin. They MUST only receive SHAs
# that already exist on origin/ — locally-created commits must never be pushed
# here directly. All changes go to origin first; private mirrors are synced by
# pushing origin/<branch> refs, not local branch refs.
#
# Valid:   git push <mirror> origin/main:main   → SHA matches origin/main ✓
# Blocked: git push <mirror> HEAD:main          → SHA not on origin ✗
#
# The mirror check only applies when origin itself is a known public host.
# If origin is absent or is also a private URL (e.g., test fixtures, local
# bare repos), we cannot enforce the mirror policy — fall through to normal gates.
ORIGIN_URL="$(git remote get-url origin 2>/dev/null || true)"
ORIGIN_IS_PUBLIC=false
if echo "$ORIGIN_URL" | grep -qE '(github\.com|gitlab\.com|bitbucket\.org)'; then
    ORIGIN_IS_PUBLIC=true
fi
if [[ "$IS_PUBLIC_REMOTE" == "false" && "$ORIGIN_IS_PUBLIC" == "true" ]]; then
    echo "  Private remote: $REMOTE_URL"
    echo "  Enforcing mirror-only policy: pushed SHAs must exist on origin."
    echo ""
    # Fetch origin to ensure refs are current — stale local refs would let
    # locally-created commits pass the SHA comparison. Network cost is
    # acceptable: this path only fires for private-remote pushes (rare).
    # Incident 2026-04-14: without this fetch, the check compared against
    # stale local refs, which could be spoofed via git update-ref.
    if ! git fetch origin --quiet 2>/dev/null; then
        echo -e "  ${RED}❌ PUSH BLOCKED: Could not fetch origin — cannot verify SHAs exist on origin.${NC}"
        echo "  Mirror-policy requires current origin refs. Check network and retry."
        echo "  If you must push offline, use: git push --no-verify"
        exit 1
    fi
    MIRROR_ERRORS=0
    while read -r _ local_sha remote_ref _; do
        [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue
        branch="${remote_ref#refs/heads/}"
        origin_sha="$(git rev-parse "origin/$branch" 2>/dev/null || true)"
        if [[ -z "$origin_sha" ]]; then
            echo -e "  ${RED}❌ PUSH BLOCKED: origin/$branch does not exist.${NC}"
            echo "  Push to origin first, then sync: git push <mirror> origin/$branch:$branch"
            MIRROR_ERRORS=$((MIRROR_ERRORS + 1))
        elif [[ "$local_sha" != "$origin_sha" ]]; then
            echo -e "  ${RED}❌ PUSH BLOCKED: $branch — pushed SHA is not on origin/$branch.${NC}"
            echo "    Pushing:        ${local_sha:0:8}"
            echo "    origin/$branch: ${origin_sha:0:8}"
            echo "  Push to origin first, then sync: git push <mirror> origin/$branch:$branch"
            MIRROR_ERRORS=$((MIRROR_ERRORS + 1))
        else
            echo -e "  ${GREEN}✓ $branch — ${local_sha:0:8} matches origin/$branch${NC}"
        fi
    done
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [[ $MIRROR_ERRORS -gt 0 ]]; then
        echo -e "${RED}  PUSH BLOCKED: $MIRROR_ERRORS mirror policy violation(s).${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        exit 1
    fi
    echo -e "${GREEN}  Mirror policy satisfied. Push allowed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
fi

# Public remote: require the IP audit script to be present.
IP_AUDIT_SCRIPT="$REPO_ROOT/tools/public-repo-ip-check.sh"
if [[ ! -f "$IP_AUDIT_SCRIPT" ]]; then
    echo -e "${RED}Missing tools/public-repo-ip-check.sh — push blocked.${NC}"
    exit 1
fi

ERRORS=0

# merge-discipline sentinel check (Gate 3): when pushing to dev|staging|main,
# verify that .merge-discipline-cleared exists, is v1 format, and its target
# field matches the ref being pushed. The sentinel is written by
# tools/merge-discipline-preflight.sh; if missing or mismatched, the push is
# blocked. This closes the round-1+2 PHR critical that the sentinel was
# advisory only and never read.
check_merge_discipline_sentinel() {
    local target_branch="$1"
    local pushed_sha="$2"
    case "$target_branch" in
        dev|staging|main) ;;
        *) return 0 ;;  # Only enforced for canonical-flow branches
    esac
    # Self-detect: skip Gate 3 entirely if the repo doesn't have the
    # merge-discipline preflight tooling installed. This keeps the hook
    # portable across test fixtures and repos that don't use this skill.
    if [[ ! -f "$REPO_ROOT/tools/merge-discipline-preflight.sh" ]]; then
        echo "  (skipped - tools/merge-discipline-preflight.sh not present in this repo)"
        return 0
    fi
    if [[ ! -f "$MERGE_DISCIPLINE_SENTINEL" ]]; then
        echo -e "  ${RED}❌ PUSH BLOCKED: No .merge-discipline-cleared sentinel.${NC}"
        echo "  Run: tools/merge-discipline-preflight.sh <source-branch> $target_branch"
        return 1
    fi
    local md_ver md_sha md_source md_target
    md_ver=$(cut -d'|' -f1 < "$MERGE_DISCIPLINE_SENTINEL" 2>/dev/null)
    md_sha=$(cut -d'|' -f2 < "$MERGE_DISCIPLINE_SENTINEL" 2>/dev/null)
    md_source=$(cut -d'|' -f3 < "$MERGE_DISCIPLINE_SENTINEL" 2>/dev/null)
    md_target=$(cut -d'|' -f4 < "$MERGE_DISCIPLINE_SENTINEL" 2>/dev/null)
    local field_count
    field_count=$(awk -F'|' '{print NF}' "$MERGE_DISCIPLINE_SENTINEL" 2>/dev/null || echo "0")
    if [[ "$md_ver" != "v1" ]] || [[ "$field_count" -ne 5 ]] || [[ -z "$md_sha" ]] || [[ -z "$md_source" ]] || [[ -z "$md_target" ]]; then
        echo -e "  ${RED}❌ PUSH BLOCKED: merge-discipline sentinel format unrecognized (expected exactly 5 fields: v1|SHA|SOURCE|TARGET|TIMESTAMP, all non-empty).${NC}"
        return 1
    fi
    if [[ "$md_target" != "$target_branch" ]]; then
        echo -e "  ${RED}❌ PUSH BLOCKED: merge-discipline sentinel target ($md_target) != pushed branch ($target_branch).${NC}"
        echo "  Re-run preflight: tools/merge-discipline-preflight.sh $md_source $target_branch"
        return 1
    fi
    if [[ "$md_sha" != "$pushed_sha" ]]; then
        echo -e "  ${RED}❌ PUSH BLOCKED: merge-discipline sentinel SHA (${md_sha:0:8}) != pushed SHA (${pushed_sha:0:8}). Branch tip moved since preflight.${NC}"
        echo "  Re-run: tools/merge-discipline-preflight.sh $md_source $target_branch"
        return 1
    fi
    echo -e "  ${GREEN}✓ merge-discipline cleared: $md_source -> $md_target (${md_sha:0:8})${NC}"
    # Consume the sentinel so a stale file doesn't accidentally clear the
    # NEXT push. The preflight is single-use per push (per the skill's
    # mandatory-behavior #1).
    rm -f "$MERGE_DISCIPLINE_SENTINEL"
    return 0
}

# Read push info from stdin (pre-push hook protocol)
while read -r _ local_sha remote_ref remote_sha; do
    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        continue  # Branch deletion, skip
    fi
    pushed_branch="${remote_ref#refs/heads/}"

    # NEW_BRANCH_NO_BASE: set to true when we cannot find a merge-base for a new
    # branch push. In that case range_is_docs_only() would only inspect the tip
    # commit (via git diff-tree), missing earlier code commits in the push.
    # We fail closed: require sentinel regardless of file types.
    NEW_BRANCH_NO_BASE=false

    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        # New branch — find merge-base with the repo's actual workflow base branch
        REMOTE_DEFAULT="$(resolve_push_base_ref || true)"
        if [[ -n "$REMOTE_DEFAULT" ]]; then
            MERGE_BASE=$(git merge-base "$local_sha" "$REMOTE_DEFAULT" 2>/dev/null || true)
            if [[ -n "$MERGE_BASE" ]]; then
                RANGE="$MERGE_BASE..$local_sha"
            else
                # No common ancestor — cannot enumerate only new commits safely.
                # Set a range but mark that docs-only detection is unreliable: the
                # single-SHA diff-tree only inspects the tip, missing earlier commits.
                RANGE="$local_sha"
                NEW_BRANCH_NO_BASE=true
            fi
        else
            RANGE="$local_sha"
            NEW_BRANCH_NO_BASE=true
        fi
    else
        RANGE="$remote_sha..$local_sha"
    fi

    echo "Checking commits: $RANGE"
    echo ""

    # Gate 1: Code review sentinel
    echo "  [Gate 1/2] Code review clearance"
    if [[ "$NEW_BRANCH_NO_BASE" == "true" ]]; then
        # No merge-base found — enumerate ALL files reachable from the tip and
        # decide if the push is truly docs-only before failing closed.
        # This over-approximates (may include ancestor commits already on the
        # remote under a different ref/tag) but is conservative: it can only
        # add false code-detections, never miss them.
        # -m shows per-parent diffs for merge commits so files introduced only
        # during conflict resolution are not silently missed.
        #
        # Track git exit code separately so we can distinguish three outcomes:
        #   (a) enumeration failed → fail closed (sentinel required)
        #   (b) succeeded, no files (--allow-empty commits only) → allow (nothing to review)
        #   (c) succeeded, files found → classify docs-only vs code
        _no_base_files=""
        _git_enum_ok=true
        _log_raw=""
        # Capture git exit code separately: grep -v '^$' returns exit 1 on empty
        # input (no matching lines), which must not be confused with a git failure.
        if ! _log_raw=$(git log --name-only -m --format="" "$local_sha" 2>/dev/null); then
            _git_enum_ok=false
        else
            _no_base_files=$(printf '%s\n' "$_log_raw" | grep -v '^$' | sort -u || true)
        fi
        _no_base_code=$(printf '%s\n' "$_no_base_files" | _first_code_file || true)

        if [[ "$_git_enum_ok" == "false" ]]; then
            # Cannot enumerate — fail closed.
            echo "  [code-review-gate] New branch with no common ancestor — failing closed (require sentinel)."
            if ! check_code_review_sentinel "REQUIRE_SENTINEL" "$local_sha"; then
                ERRORS=$((ERRORS + 1))
            fi
        elif [[ -z "$_no_base_files" ]]; then
            # Enumeration succeeded but no files changed (only --allow-empty commits).
            # Nothing to review — allow without sentinel.
            echo "  [code-review-gate] New branch (no common ancestor) — no file changes (allow-empty only), sentinel not required."
        elif [[ -z "$_no_base_code" ]]; then
            # Files found, all docs/metadata — allow without sentinel.
            echo "  [code-review-gate] New branch (no common ancestor) — all commits docs-only, sentinel not required."
        else
            # Code commits present — fail closed.
            echo "  [code-review-gate] New branch with no common ancestor — failing closed (require sentinel)."
            if ! check_code_review_sentinel "REQUIRE_SENTINEL" "$local_sha"; then
                ERRORS=$((ERRORS + 1))
            fi
        fi
    elif ! check_code_review_sentinel "$RANGE" "$local_sha"; then
        ERRORS=$((ERRORS + 1))
    fi
    echo ""

    # Gate 2: Proprietary IP scan (public remotes only)
    echo "  [Gate 2/3] Proprietary IP scan"
    if [[ "$IS_PUBLIC_REMOTE" == "true" ]]; then
        if ! bash "$IP_AUDIT_SCRIPT" --range "$RANGE"; then
            ERRORS=$((ERRORS + 1))
        fi
    else
        echo "  (skipped — private remote: $REMOTE_URL)"
    fi
    echo ""

    # Gate 3: merge-discipline sentinel (only for pushes to dev|staging|main).
    # Other branches (feature/*, fix/*, hotfix/*, forward/*, etc.) are exempt
    # because they don't represent a promotion landing. The preflight script
    # writes the sentinel and the PR-create call is the action it gates.
    echo "  [Gate 3/3] merge-discipline sentinel (canonical-flow targets only)"
    case "$pushed_branch" in
        dev|staging|main)
            if ! check_merge_discipline_sentinel "$pushed_branch" "$local_sha"; then
                ERRORS=$((ERRORS + 1))
            fi
            ;;
        *)
            echo "  (skipped — pushing to '$pushed_branch', not a canonical-flow branch)"
            ;;
    esac
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}  PUSH BLOCKED: $ERRORS gate(s) failed.${NC}"
    echo ""
    echo "  Fix all issues above, then push again."
    echo "  DO NOT use --no-verify."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
else
    echo -e "${GREEN}  All gates passed. Push allowed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    # Record gate evidence in workflow state (advisory, non-blocking)
    if command -v node >/dev/null 2>&1 && [[ -f "$REPO_ROOT/lib/workflow-state.js" ]]; then
        node -e "
            try {
                const ws = require('$REPO_ROOT/lib/workflow-state');
                ws.recordGate('code_review', { tool: 'pre-push', exit_code: 0 });
            } catch(e) {}
        " 2>/dev/null || true
    fi
    exit 0
fi
