#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# pre-push (composer)
#
# The repo-local pre-push hook entry point. Captures git's stdin ref list
# into a temp file once and replays that same file, fresh, to every gate
# script below -- each gate is invoked as its own process, so a naive
# single stdin read would be consumed by whichever gate ran first, leaving
# every later gate with nothing to check (a silent fail-open, not just a
# hang, if any single gate accidentally reads a stray line from an
# unprotected stdin).
#
# Gates run, in order (a non-zero exit from any gate is aggregated into the
# final failure count -- ALL gates run so a single push attempt reports
# everything wrong at once, not just the first failure):
#   1. tools/pre-push-test-gate.sh              -- local fast test suite (tools/test-all.sh --fast)
#   2. tools/pre-push-code-review-gate.sh       -- code-review-battery sentinel (excludes skills/*.md)
#   3. tools/pre-push-ip-scan-gate.sh           -- proprietary IP scan (public remotes only)
#   4. tools/pre-push-branch-flow-gate.sh       -- branch-flow sentinel (dev|staging|main only)
#   5. tools/pre-push-phr-gate.sh               -- PHR sentinel (design .md only, excludes skills/*.md)
#   6. tools/pre-push-llm-skill-review-gate.sh  -- llm-skill-review sentinel (skills/*.md ONLY --
#                                                   supersedes gates 2 and 5 for this file class)
#
# INSTALL: ./tools/install-hooks.sh
# Bypass:  `git push --no-verify` skips the hook entirely (git design limit).
# -----------------------------------------------------------------------------
set -euo pipefail

# Git sets GIT_DIR (and GIT_PREFIX; confirmed via direct repro under a linked
# worktree -- GIT_WORK_TREE/GIT_INDEX_FILE were not observed auto-set in that
# repro) in the hook subprocess environment, needed so hooks under a linked
# worktree resolve the right worktree. All 4 are unset below regardless: a
# future git version or a hook invoked another way could set any of them, and
# confirmed separately that GIT_WORK_TREE alone -- independent of GIT_DIR --
# is equally sufficient to redirect `git rev-parse --show-toplevel` onto a
# decoy repo, so this isn't over-cautious defense against a vector that
# doesn't exist; it's covering a second, equally real one. Gate 1 shells out
# to `tools/test-all.sh --fast` -> bats, whose fixtures do their own `git -C
# <tmpdir> init/commit` assuming normal cwd-based repo discovery. Left set,
# GIT_DIR overrides `-C`/cwd discovery for ANY nested git invocation, silently
# redirecting supposedly isolated fixture operations onto THIS repo instead.
# Unsetting here is safe: cwd is already correct for this worktree (git
# invoked the hook with the pushing worktree as cwd), so plain discovery
# still resolves this repo correctly for the gates that need it. Each gate
# script re-unsets independently too (defense in depth for when a gate is
# invoked directly, bypassing this composer).
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_PREFIX

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [[ -z "$REPO_ROOT" ]]; then
    if [[ "$SCRIPT_DIR" == *".git/hooks"* ]]; then
        REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    else
        REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
    fi
fi

cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

TOOLS_DIR="$REPO_ROOT/tools"
TEST_GATE="$TOOLS_DIR/pre-push-test-gate.sh"
CODE_REVIEW_GATE="$TOOLS_DIR/pre-push-code-review-gate.sh"
IP_SCAN_GATE="$TOOLS_DIR/pre-push-ip-scan-gate.sh"
BRANCH_FLOW_GATE="$TOOLS_DIR/pre-push-branch-flow-gate.sh"
PHR_GATE="$TOOLS_DIR/pre-push-phr-gate.sh"
LLM_SKILL_REVIEW_GATE="$TOOLS_DIR/pre-push-llm-skill-review-gate.sh"

# Remote name is passed as $1 by git
REMOTE_NAME="${1:-origin}"

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  PRE-PUSH: Running quality gates..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Private remotes are downstream mirrors of origin. They MUST only receive SHAs
# that already exist on origin/ -- locally-created commits must never be pushed
# here directly. All changes go to origin first; private mirrors are synced by
# pushing origin/<branch> refs, not local branch refs.
#
# Valid:   git push <mirror> origin/main:main   -> SHA matches origin/main OK
# Blocked: git push <mirror> HEAD:main          -> SHA not on origin FAIL
#
# The mirror check only applies when origin itself is a known public host.
# If origin is absent or is also a private URL (e.g., test fixtures, local
# bare repos), we cannot enforce the mirror policy -- fall through to the
# normal gates below instead. This is a distinct, whole-push concern (not a
# per-commit-range gate), so it stays here in the composer rather than
# becoming its own gate script.
REMOTE_URL="$(git remote get-url "$REMOTE_NAME" 2>/dev/null || echo "")"
ORIGIN_URL="$(git remote get-url origin 2>/dev/null || true)"
IS_PUBLIC_REMOTE=true
if [[ -n "$REMOTE_URL" ]] && ! echo "$REMOTE_URL" | grep -qE '(github\.com|gitlab\.com|bitbucket\.org)'; then
    IS_PUBLIC_REMOTE=false
fi
ORIGIN_IS_PUBLIC=false
if echo "$ORIGIN_URL" | grep -qE '(github\.com|gitlab\.com|bitbucket\.org)'; then
    ORIGIN_IS_PUBLIC=true
fi

if [[ "$IS_PUBLIC_REMOTE" == "false" && "$ORIGIN_IS_PUBLIC" == "true" ]]; then
    echo "  Private remote: $REMOTE_URL"
    echo "  Enforcing mirror-only policy: pushed SHAs must exist on origin."
    echo ""
    # Fetch origin to ensure refs are current -- stale local refs would let
    # locally-created commits pass the SHA comparison. Network cost is
    # acceptable: this path only fires for private-remote pushes (rare).
    # Incident 2026-04-14: without this fetch, the check compared against
    # stale local refs, which could be spoofed via git update-ref.
    if ! git fetch origin --quiet 2>/dev/null; then
        echo -e "  ${RED}❌ PUSH BLOCKED: Could not fetch origin — cannot verify SHAs exist on origin.${NC}"
        echo "  Mirror-policy requires current origin refs. Check network and retry."
        echo "  If you must push offline, use: git push --no-verify"
        exit 1
    fi
    MIRROR_ERRORS=0
    while read -r _ local_sha remote_ref _; do
        [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue
        branch="${remote_ref#refs/heads/}"
        origin_sha="$(git rev-parse "origin/$branch" 2>/dev/null || true)"
        if [[ -z "$origin_sha" ]]; then
            echo -e "  ${RED}❌ PUSH BLOCKED: origin/$branch does not exist.${NC}"
            echo "  Push to origin first, then sync: git push <mirror> origin/$branch:$branch"
            MIRROR_ERRORS=$((MIRROR_ERRORS + 1))
        elif [[ "$local_sha" != "$origin_sha" ]]; then
            echo -e "  ${RED}❌ PUSH BLOCKED: $branch — pushed SHA is not on origin/$branch.${NC}"
            echo "    Pushing:        ${local_sha:0:8}"
            echo "    origin/$branch: ${origin_sha:0:8}"
            echo "  Push to origin first, then sync: git push <mirror> origin/$branch:$branch"
            MIRROR_ERRORS=$((MIRROR_ERRORS + 1))
        else
            echo -e "  ${GREEN}✓ $branch — ${local_sha:0:8} matches origin/$branch${NC}"
        fi
    done
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [[ $MIRROR_ERRORS -gt 0 ]]; then
        echo -e "${RED}  PUSH BLOCKED: $MIRROR_ERRORS mirror policy violation(s).${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        exit 1
    fi
    echo -e "${GREEN}  Mirror policy satisfied. Push allowed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
fi

# Capture stdin once; replay to each gate.
STDIN_CAPTURE="$(mktemp "${TMPDIR:-/tmp}/pre-push-stdin.XXXXXX")"
trap 'rm -f "$STDIN_CAPTURE"' EXIT
cat > "$STDIN_CAPTURE"

# Invoke each gate via `bash` (not by exec bit) so a gate file that lost its
# executable bit -- zip/tarball export, core.fileMode=false, restrictive umask
# after checkout -- is still enforced rather than silently skipped. Absence is
# announced, never silent. All gates run regardless of earlier gate outcomes
# so a single push attempt reports every failing gate at once.
ERRORS=0

echo "  [Gate 1/6] Local fast test suite (tools/test-all.sh --fast)"
if [[ -f "$TEST_GATE" ]]; then
    bash "$TEST_GATE" < "$STDIN_CAPTURE" || ERRORS=$((ERRORS + 1))
else
    echo "  (skipped — tools/pre-push-test-gate.sh not present)"
fi
echo ""

echo "  [Gate 2/6] Code review clearance"
if [[ -f "$CODE_REVIEW_GATE" ]]; then
    bash "$CODE_REVIEW_GATE" "$REMOTE_NAME" < "$STDIN_CAPTURE" || ERRORS=$((ERRORS + 1))
else
    # Unlike the test/branch-flow/PHR gates, this one has no "optional
    # tooling not installed in this repo" exemption -- the original monolith
    # enforced code-review clearance unconditionally, baked into the one
    # file that was always installed. A missing gate script here (bad
    # merge, partial checkout, accidental rm) must fail closed, not be
    # treated as "not applicable."
    echo -e "  ${RED}❌ PUSH BLOCKED: tools/pre-push-code-review-gate.sh is missing.${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

echo "  [Gate 3/6] Proprietary IP scan"
if [[ -f "$IP_SCAN_GATE" ]]; then
    bash "$IP_SCAN_GATE" "$REMOTE_NAME" < "$STDIN_CAPTURE" || ERRORS=$((ERRORS + 1))
else
    # Same reasoning as Gate 2: no optional-tooling exemption in the original.
    echo -e "  ${RED}❌ PUSH BLOCKED: tools/pre-push-ip-scan-gate.sh is missing.${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

echo "  [Gate 4/6] branch-flow sentinel (canonical-flow targets only)"
if [[ -f "$BRANCH_FLOW_GATE" ]]; then
    bash "$BRANCH_FLOW_GATE" < "$STDIN_CAPTURE" || ERRORS=$((ERRORS + 1))
else
    echo "  (skipped — tools/pre-push-branch-flow-gate.sh not present)"
fi
echo ""

echo "  [Gate 5/6] PHR sentinel (design .md only, excludes skills/*.md)"
if [[ -f "$PHR_GATE" ]]; then
    bash "$PHR_GATE" "$REMOTE_NAME" < "$STDIN_CAPTURE" || ERRORS=$((ERRORS + 1))
else
    echo "  (skipped — tools/pre-push-phr-gate.sh not present)"
fi
echo ""

echo "  [Gate 6/6] llm-skill-review sentinel (skills/*.md only)"
if [[ -f "$LLM_SKILL_REVIEW_GATE" ]]; then
    bash "$LLM_SKILL_REVIEW_GATE" "$REMOTE_NAME" < "$STDIN_CAPTURE" || ERRORS=$((ERRORS + 1))
else
    # Same reasoning as Gates 2/3: this gate is now the SOLE reviewer for
    # skills/*.md (Gates 2 and 5 both statically exempt that file class
    # regardless of whether this script exists), so a missing script here
    # must fail closed too -- otherwise a skills/*.md-only push would sail
    # through with zero review of any kind.
    echo -e "  ${RED}❌ PUSH BLOCKED: tools/pre-push-llm-skill-review-gate.sh is missing.${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}  PUSH BLOCKED: $ERRORS gate(s) failed.${NC}"
    echo ""
    echo "  Fix all issues above, then push again."
    echo "  DO NOT use --no-verify."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
else
    echo -e "${GREEN}  All gates passed. Push allowed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    # Record gate evidence in workflow state (advisory, non-blocking)
    if command -v node >/dev/null 2>&1 && [[ -f "$REPO_ROOT/lib/workflow-state.js" ]]; then
        node -e "
            try {
                const ws = require('$REPO_ROOT/lib/workflow-state');
                ws.recordGate('code_review', { tool: 'pre-push', exit_code: 0 });
            } catch(e) {}
        " 2>/dev/null || true
    fi
    exit 0
fi
