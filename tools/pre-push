#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# Pre-push hook for superpowers-plus
# PURPOSE: Block pushes that contain proprietary IP in unpushed commits
# INSTALL: ./tools/install-hooks.sh
# -----------------------------------------------------------------------------
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"

if [[ -z "$REPO_ROOT" ]]; then
    if [[ "$SCRIPT_DIR" == *".git/hooks"* ]]; then
        REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    else
        REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
    fi
fi

cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

# -----------------------------------------------------------------------------
# Code Review Sentinel Check
# Purpose: Block pushes of code changes that have not been cleared by
#          code-review-battery. The battery writes .code-review-cleared
#          (format: v1|SHA|VERDICT|TIMESTAMP) when it passes. This hook
#          verifies the clearance exists, matches the pushed ref SHA, and has a
#          passing verdict.
# Bypass:  Local git hooks can be bypassed with --no-verify. This is a
#          workflow gate, not a security boundary. For hard enforcement, add
#          server-side push rules or CI required checks.
# Threat:  Local soft gate only. An agent can forge the file. This is
#          intentional — policy-enforced, not security-enforced.
# -----------------------------------------------------------------------------
SENTINEL_FILE="$REPO_ROOT/.code-review-cleared"

# Returns 0 if the range contains only prose/metadata files that cannot alter
# runtime behavior. JSON/YAML/TOML/shell config ARE code for purposes of this
# check — they can change scope guards, deploy behavior, and security boundaries.
# Only pure docs and well-known root metadata files are exempted.
range_is_docs_only() {
    local range="$1"
    local all_files code_files
    # For single-SHA ranges (new branch with no merge-base), git diff compares
    # to the working tree — use diff-tree instead to enumerate only the commit's
    # changed files. --root handles root commits; -m handles merge commits (lists
    # files relative to each parent); sort -u deduplicates multi-parent output.
    # Use `if !` to fail closed on git errors without triggering set -e: if we
    # cannot enumerate files, treat the range as code (require sentinel).
    if [[ "$range" != *".."* ]]; then
        if ! all_files=$(git diff-tree --root -m --no-commit-id --name-only -r "${range}" 2>/dev/null | sort -u); then
            return 1  # Cannot enumerate commit files — fail closed (not docs-only)
        fi
    else
        if ! all_files=$(git diff --name-only "$range" 2>/dev/null); then
            return 1  # Cannot enumerate range files — fail closed
        fi
    fi
    # AGENTS.md and CLAUDE.md are policy files — treated as code. Changes to
    # them alter agent gate behavior and must not be exempted as docs.
    # awk preserves them before the generic .md exemption applies.
    # The || true is scoped to the FILTER pipeline only — not the git commands
    # above — so real git failures still fail closed (return 1 via if ! above).
    code_files=$(printf '%s\n' "$all_files" \
        | awk '
            /^\s*$/                             { next }
            /^(AGENTS|CLAUDE)(\.md)?$/          { print; next }
            /^skills\//                         { print; next }
            /\.(md|txt|rst)$/                   { next }
            /^(\.gitignore|\.gitattributes|\.editorconfig|README|CHANGELOG|LICENSE|\.env\.example)$/ { next }
            { print }
        ' \
        | head -1 || true)
    [[ -z "$code_files" ]]
}

# $1 = RANGE (commit range being pushed)
# $2 = local_sha (the actual ref SHA being pushed — may differ from HEAD)
check_code_review_sentinel() {
    local range="$1"
    local pushed_sha="$2"

    if range_is_docs_only "$range"; then
        echo -e "  ${YELLOW}[code-review-gate]${NC} Docs only — sentinel not required."
        return 0
    fi

    echo "  [code-review-gate] Code changes detected — checking clearance..."

    if [[ ! -f "$SENTINEL_FILE" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: No code review clearance found.${NC}"
        echo ""
        echo "  Code changes require code-review-battery before pushing."
        echo "  The battery writes .code-review-cleared when it passes PASS or PASS_WITH_NITS."
        echo ""
        echo "  Steps:"
        echo "    1. node ~/.codex/superpowers-augment/superpowers-augment.js use-skill code-review-battery"
        echo "    2. Dispatch reviewers with: git diff \$(git merge-base HEAD \$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || echo 'origin/dev'))..HEAD"
        echo "    3. Battery writes .code-review-cleared on PASS/PASS_WITH_NITS"
        echo "    4. git push"
        echo ""
        return 1
    fi

    local sentinel_ver sentinel_sha sentinel_verdict sentinel_ts
    sentinel_ver=$(cut -d'|' -f1 < "$SENTINEL_FILE" 2>/dev/null || echo "")
    sentinel_sha=$(cut -d'|' -f2 < "$SENTINEL_FILE" 2>/dev/null || echo "")
    sentinel_verdict=$(cut -d'|' -f3 < "$SENTINEL_FILE" 2>/dev/null || echo "")
    sentinel_ts=$(cut -d'|' -f4 < "$SENTINEL_FILE" 2>/dev/null || echo "")

    # Validate v1 format: exactly 4 pipe-delimited fields, field 1 is "v1",
    # field 2 (sha) and field 4 (timestamp) must be non-empty.
    local field_count
    field_count=$(awk -F'|' '{print NF}' "$SENTINEL_FILE" 2>/dev/null || echo "0")

    if [[ "$sentinel_ver" != "v1" ]] || [[ "$field_count" != "4" ]] || [[ -z "$sentinel_sha" ]] || [[ -z "$sentinel_ts" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: Sentinel file format unrecognized (expected v1|SHA|VERDICT|TIMESTAMP, all fields non-empty).${NC}"
        echo ""
        echo "  Delete .code-review-cleared and re-run code-review-battery."
        echo ""
        return 1
    fi

    # Compare against the ref actually being pushed, not necessarily HEAD.
    # Pre-push hooks can push non-HEAD refs (e.g., worktrees, detached heads).
    if [[ "$sentinel_sha" != "$pushed_sha" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: Code review clearance is stale.${NC}"
        echo ""
        echo "  Clearance was for commit: ${sentinel_sha:0:8}"
        echo "  Pushing commit:           ${pushed_sha:0:8}"
        echo ""
        echo "  Commits were made after the review. Re-run code-review-battery, then push."
        echo ""
        return 1
    fi

    if [[ "$sentinel_verdict" != "PASS" && "$sentinel_verdict" != "PASS_WITH_NITS" ]]; then
        echo ""
        echo -e "  ${RED}❌ PUSH BLOCKED: Code review verdict was not passing.${NC}"
        echo ""
        echo "  Last verdict: $sentinel_verdict (at $sentinel_ts)"
        echo "  Fix all Critical and Important findings, re-run battery."
        echo ""
        return 1
    fi

    echo -e "  ${GREEN}✓ Code review cleared: $sentinel_verdict (${sentinel_sha:0:8}, $sentinel_ts)${NC}"
    return 0
}

IP_AUDIT_SCRIPT="$REPO_ROOT/tools/public-repo-ip-check.sh"
if [[ ! -f "$IP_AUDIT_SCRIPT" ]]; then
    echo -e "${RED}Missing tools/public-repo-ip-check.sh — push blocked.${NC}"
    exit 1
fi

# Remote name is passed as $1 by git
REMOTE_NAME="${1:-origin}"

resolve_push_base_ref() {
    local candidate tracking
    tracking="$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)"

    for candidate in \
        "$tracking" \
        "$REMOTE_NAME/dev" "$REMOTE_NAME/staging" "$REMOTE_NAME/main" "$REMOTE_NAME/master" \
        origin/dev origin/staging origin/main origin/master \
        upstream/dev upstream/staging upstream/main upstream/master \
        gitlab/dev gitlab/staging gitlab/main gitlab/master
    do
        [[ -n "$candidate" ]] || continue
        if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  PRE-PUSH: Running quality gates..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ERRORS=0

# Read push info from stdin (pre-push hook protocol)
while read -r _ local_sha _ remote_sha; do
    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        continue  # Branch deletion, skip
    fi

    # NEW_BRANCH_NO_BASE: set to true when we cannot find a merge-base for a new
    # branch push. In that case range_is_docs_only() would only inspect the tip
    # commit (via git diff-tree), missing earlier code commits in the push.
    # We fail closed: require sentinel regardless of file types.
    NEW_BRANCH_NO_BASE=false

    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        # New branch — find merge-base with the repo's actual workflow base branch
        REMOTE_DEFAULT="$(resolve_push_base_ref || true)"
        if [[ -n "$REMOTE_DEFAULT" ]]; then
            MERGE_BASE=$(git merge-base "$local_sha" "$REMOTE_DEFAULT" 2>/dev/null || true)
            if [[ -n "$MERGE_BASE" ]]; then
                RANGE="$MERGE_BASE..$local_sha"
            else
                # No common ancestor — cannot enumerate only new commits safely.
                # Set a range but mark that docs-only detection is unreliable: the
                # single-SHA diff-tree only inspects the tip, missing earlier commits.
                RANGE="$local_sha"
                NEW_BRANCH_NO_BASE=true
            fi
        else
            RANGE="$local_sha"
            NEW_BRANCH_NO_BASE=true
        fi
    else
        RANGE="$remote_sha..$local_sha"
    fi

    echo "Checking commits: $RANGE"
    echo ""

    # Gate 1: Code review sentinel
    echo "  [Gate 1/2] Code review clearance"
    if [[ "$NEW_BRANCH_NO_BASE" == "true" ]]; then
        # No merge-base found — enumerate ALL files reachable from the tip and
        # decide if the push is truly docs-only before failing closed.
        # This over-approximates (may include ancestor commits already on the
        # remote under a different ref/tag) but is conservative: it can only
        # add false code-detections, never miss them.
        # -m shows per-parent diffs for merge commits so files introduced only
        # during conflict resolution are not silently missed.
        _no_base_files=$(git log --name-only -m --format="" "$local_sha" 2>/dev/null \
            | grep -v '^$' | sort -u || true)
        _no_base_code=$(printf '%s\n' "$_no_base_files" \
            | awk '
                /^\s*$/                             { next }
                /^(AGENTS|CLAUDE)(\.md)?$/          { print; next }
                /^skills\//                         { print; next }
                /\.(md|txt|rst)$/                   { next }
                /^(\.gitignore|\.gitattributes|\.editorconfig|README|CHANGELOG|LICENSE|\.env\.example)$/ { next }
                { print }
            ' | head -1 || true)
        if [[ -n "$_no_base_files" && -z "$_no_base_code" ]]; then
            echo "  [code-review-gate] New branch (no common ancestor) — all commits docs-only, sentinel not required."
        else
            # Code commits present, or could not enumerate files — fail closed.
            echo "  [code-review-gate] New branch with no common ancestor — failing closed (require sentinel)."
            if ! check_code_review_sentinel "REQUIRE_SENTINEL" "$local_sha"; then
                ERRORS=$((ERRORS + 1))
            fi
        fi
    elif ! check_code_review_sentinel "$RANGE" "$local_sha"; then
        ERRORS=$((ERRORS + 1))
    fi
    echo ""

    # Gate 2: Proprietary IP scan
    echo "  [Gate 2/2] Proprietary IP scan"
    if ! bash "$IP_AUDIT_SCRIPT" --range "$RANGE"; then
        ERRORS=$((ERRORS + 1))
    fi
done

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}  PUSH BLOCKED: $ERRORS gate(s) failed.${NC}"
    echo ""
    echo "  Fix all issues above, then push again."
    echo "  DO NOT use --no-verify."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
else
    echo -e "${GREEN}  All gates passed. Push allowed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 0
fi
