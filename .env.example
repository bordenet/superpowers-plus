# =============================================================================
# superpowers-plus/.env.example
# =============================================================================
# Copy to ~/.codex/.env and fill in your values. This file documents every
# variable the superpowers ecosystem may consume. No secrets here — this file
# is committed to git.
#
# CREDENTIAL POLICY:
#   - Dev/Staging: any credentials may be stored in ~/.codex/.env
#   - Prod: ONLY read-only credentials. NEVER store write-capable prod creds.
# =============================================================================

# --- Local Paths ---
# TODO_FILE_PATH="$HOME/path/to/TODO.md"          # Primary TODO persistence
# ONEDRIVE_ROOT="/path/to/OneDrive"                # OneDrive sync root
# RECRUITING_DIR="/path/to/recruiting"              # Recruiting docs (PII — never commit)

# =============================================================================
# SaaS API Keys
# =============================================================================

# Linear (project management) — https://linear.app/settings/api
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# Outline Wiki — https://your-wiki.example.com/settings/api
# OUTLINE_API_KEY=ol_api_xxxxxxxxxxxx
# OUTLINE_API_URL=https://your-wiki.example.com/api
# OUTLINE_BASE_URL=https://your-wiki.example.com
# WIKI_LOCAL_PATH=./path/to/wiki/

# Postman — https://web.postman.co/settings/me/api-keys
# POSTMAN_API_KEY=PMAK-xxxxxxxxxxxx

# Meeting transcription service
# MEETING_TRANSCRIPTION_API_KEY=xxxxxxxxxxxx
# MEETING_TRANSCRIPTION_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# SendGrid (email) — https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# Grafana (monitoring) — create a service account token in Grafana
# GRAFANA_URL=https://your-grafana.example.com
# GRAFANA_SERVICE_ACCOUNT_TOKEN=xxxxxxxxxxxx

# Monday.com — https://monday.com/developers/apps
# MONDAY_TOKEN=xxxxxxxxxxxx

# =============================================================================
# DevOps / Source Control
# =============================================================================

# GitLab — https://gitlab.example.com/-/user_settings/personal_access_tokens
# GITLAB_PAT=glpat-xxxxxxxxxxxx

# =============================================================================
# AI / LLM Provider Keys
# =============================================================================

# OpenAI — https://platform.openai.com/api-keys
# Used for skill matching (optional; TF-IDF works without it)
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Perplexity — https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=pplx_xxxxxxxxxxxx
# THINK_TWICE_USE_PERPLEXITY=false  # ~$0.01/query, disabled by default

# Google AI — https://aistudio.google.com/apikey
# GOOGLE_AI_SECRET=xxxxxxxxxxxx

# Cerebras — https://cloud.cerebras.ai/
# CEREBRAS_AI_SECRET=xxxxxxxxxxxx

# Groq — https://console.groq.com/keys
# GROQ_AI_SECRET=xxxxxxxxxxxx

# OpenRouter — https://openrouter.ai/keys
# OPEN_ROUTER_AI_SECRET=xxxxxxxxxxxx

# =============================================================================
# Issue Tracking (required for issue-tracking/* skills)
# =============================================================================
# ISSUE_TRACKER_TYPE=github  # github, jira, or your adapter key (see skills/issue-tracking/_adapters/platform-template.md)
# ISSUE_TRACKER_API_KEY=xxxxxxxxxxxx

# GitHub (if ISSUE_TRACKER_TYPE=github)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Jira (if ISSUE_TRACKER_TYPE=jira)
# JIRA_API_TOKEN=xxxxxxxxxxxx
# JIRA_BASE_URL=https://your-org.atlassian.net

# =============================================================================
# Wiki (required for wiki/* skills)
# =============================================================================
# WIKI_PLATFORM=your-wiki  # See skills/wiki/_adapters/platform-template.md
# WIKI_API_KEY=xxxxxxxxxxxx
# WIKI_BASE_URL=https://your-wiki.example.com

# =============================================================================
# Superpowers Overlay Source Dirs (for sp-doctor drift detection)
# =============================================================================
# Each overlay repo registers itself here during install.
# sp-doctor auto-discovers all *_SOURCE_DIR vars.
# SPP_SOURCE_DIR="/path/to/superpowers-plus"       # Base (set by install.sh)
# MYTEAM_SOURCE_DIR="/path/to/superpowers-myteam"   # Your private overlay

# =============================================================================
# MCP Server Connections
# =============================================================================
# See mcp-servers/mssql/.env.sample for MSSQL connection template
# See mcp-servers/postgres/.env.sample for Postgres connection template
#
# MSSQL: MSSQL_CONN_{NAME}_{FIELD} (e.g., MSSQL_CONN_MYDB_PROD_HOST=...)
# Postgres: PG_CONN_{NAME}_{FIELD} (e.g., PG_CONN_CONFIG_DEV_HOST=...)
#
# Prod connections MUST use read-only database credentials.
# MSSQL_MAX_ROWS=1000
# PG_MAX_ROWS=1000

# =============================================================================
# Claude Code Guardrails (PR-0 scaffolding — no active behavior yet)
# See internal wiki: "claude-code-self-debug-12-point-action-plan" for details
# =============================================================================
# Kill switch for the entire guardrails subsystem (PR-3+). Default OFF until
# the hooks have been baked in staging. Set to 1 to enable once PR-1 lands.
SUPERPOWERS_CLAUDE_GUARDRAILS=0

# Per-hook bypass for ops escape hatches (PR-1+). When set to 1, individual
# Claude hook scripts skip their guard logic. Only for emergency rollback.
CLAUDE_HOOKS_BYPASS=0

# Parity-mode toggle (PR-2+). When set to 1, Augment-side and Claude-side
# quality gates run in lock-step for cross-tool parity validation.
AUGMENT_PARITY_OFF=0
