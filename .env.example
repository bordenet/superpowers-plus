# superpowers-plus/.env.example
# Copy to .env and fill in your values
# cp .env.example .env

# =============================================================================
# Issue Tracking (required for issue-tracking/* skills)
# =============================================================================
ISSUE_TRACKER_TYPE=your-tracker  # Example: github, jira, azure-devops, internal adapter

# Issue tracker adapter credentials (set the vars your adapter requires)
ISSUE_TRACKER_API_KEY=replace_me

# GitHub (if ISSUE_TRACKER_TYPE=github)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Jira (if ISSUE_TRACKER_TYPE=jira)
JIRA_API_TOKEN=xxxxxxxxxxxx
JIRA_BASE_URL=https://your-org.atlassian.net

# Azure DevOps (if ISSUE_TRACKER_TYPE=azure-devops)
AZURE_DEVOPS_PAT=xxxxxxxxxxxx
AZURE_DEVOPS_ORG=your-org

# =============================================================================
# Perplexity (required for perplexity-research skill)
# Get from: https://www.perplexity.ai/settings/api
# =============================================================================
PERPLEXITY_API_KEY=pplx_xxxxxxxxxxxx

# Enable Perplexity for think-twice skill (costs ~$0.01/query)
# Default: false (disabled to avoid unexpected costs)
THINK_TWICE_USE_PERPLEXITY=false

# =============================================================================
# Wiki (required for wiki/* skills)
# See skills/wiki/_adapters/ for platform-specific setup
# =============================================================================
WIKI_PLATFORM=your-wiki  # Example: confluence, notion, gitbook, internal adapter

# Wiki adapter credentials (set the vars your adapter requires)
WIKI_API_KEY=replace_me
WIKI_BASE_URL=https://your-wiki.example.com
