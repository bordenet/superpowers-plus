# =============================================================================
# OneDrive / cloud sync artifacts
# =============================================================================
# OneDrive creates random-named temp/conflict files (commas, tildes, hashes)
*,*
*#*#
~$*
~*
*~
*.tmp
*.temp
.~lock.*

# =============================================================================
# macOS
# =============================================================================
.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.fseventsd
.apdisk
Icon?
Thumbs.db

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.github/instructions/codacy.instructions.md

# =============================================================================
# Environment / secrets
# =============================================================================
.env

# =============================================================================
# Build / runtime artifacts
# =============================================================================
node_modules/
npm-debug.log*
*.log
*.backup
*.bak
.cache/

# =============================================================================
# Project-specific
# =============================================================================
# Profanity patterns - root-level file is for local overrides (not tracked)
# scripts/.profanity-patterns.txt IS tracked - it's the reference list
/.profanity-patterns.txt

# Slop detection workspace files
.slop-dictionary.json
.slop-metrics.json

# Session state
.superpowers-session

# Code review sentinel (written by code-review-battery, read by pre-push hook)
# Never commit — it is HEAD-specific and machine-local
.code-review-cleared

# wiki-instruction-guard local domain allowlist (org-specific, never committed)
skills/security/wiki-instruction-guard/references/domain-allowlist-local.md

# Local-only IP patterns for pre-commit/pre-push scanning
.ip-patterns
.ip-check-patterns
__pycache__/
install-state/

# Internal planning, design, and operational docs — not for public repo
docs/superpowers/plans/
docs/superpowers/specs/
docs/superpowers/multi-agent/

# Internal operational tooling — not for public repo
tools/internal-sync.sh

# Local AI agent guidance (machine-specific operational notes)
.ai-guidance/
.augment-review/
